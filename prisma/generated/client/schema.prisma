generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  user
  core
}

model User {
  id       Int        @id @default(autoincrement())
  username String     @unique
  name     String?
  password String?
  userType UserType   @default(user)
  meets    UserMeet[]
}

model Meet {
  id        Int        @id @default(autoincrement())
  name      String
  date      DateTime
  attendees UserMeet[]
  points    Int        @default(1)
}

model UserMeet {
  id     Int  @id @default(autoincrement())
  userId Int
  meetId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  meet   Meet @relation(fields: [meetId], references: [id], onDelete: Cascade)

  @@unique([userId, meetId]) // Ensures a user can't register for the same event twice
}
